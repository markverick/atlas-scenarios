{
  "_comment": "Active prefix-scale queue: Sprint, two_step, prefixes 0..50 in steps of 5, sim+emu, snapshots disabled. Run with: sudo ./jobs.sh start --fresh prefix_scale/sprint_twostep_0to50",
  "selector": "prefix_scale/sprint_twostep_0to50",
  "name": "sprint_twostep_0to50",
  "experiment": "prefix_scale",
  "topology": "sprint",
  "mode": "two_step",
  "description": "Sprint two-step prefix-scale sweep for sim and emu, prefixes 0..50 in steps of 5",
  "run_root_template": "experiments/prefix_scale/results/sprint_twostep_0to50/{timestamp}",
  "jobs": [
    {
      "name": "build",
      "cmd": "./run.sh build"
    },
    {
      "name": "sim two_step p{prefixes}",
      "cmd": "./run.sh sim --no-build churn.py --config experiments/prefix_scale/scenarios/sprint_twostep_sim_0to50.json --out {run_root}/sim --mode two_step --prefixes {prefixes} --append",
      "matrix": {"prefixes": [0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50]}
    },
    {
      "name": "emu two_step p{prefixes}",
      "cmd": "./run.sh emu --no-build churn.py --config experiments/prefix_scale/scenarios/sprint_twostep_emu_0to50.json --out {run_root}/emu --mode two_step --prefixes {prefixes} --append",
      "matrix": {"prefixes": [0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50]}
    },
    {
      "name": "plot sim-vs-emu 0to50",
      "cmd": "python3 experiments/prefix_scale/plot.py --data {run_root}/emu --data2 {run_root}/sim --out {run_root}/compare"
    }
  ]
}