{
  "_comment": "Sprint p=50 burst test: no churn, just measure initial PfxSync convergence duration. Run with: sudo ./jobs.sh start --fresh prefix_scale/sprint_p50_burst",
  "selector": "prefix_scale/sprint_p50_burst",
  "name": "sprint_p50_burst",
  "experiment": "prefix_scale",
  "topology": "sprint",
  "mode": "two_step",
  "description": "Sprint p=50 burst measurement — sim and emu, no churn events, 60s window",
  "run_root_template": "experiments/prefix_scale/results/sprint_p50_burst/{timestamp}",
  "jobs": [
    {
      "name": "build",
      "cmd": "./run.sh build"
    },
    {
      "name": "sim two_step p50",
      "cmd": "./run.sh sim --no-build churn.py --config experiments/prefix_scale/scenarios/sprint_twostep_sim_p50_burst.json --out {run_root}/sim --mode two_step --prefixes 50 --append"
    },
    {
      "name": "emu two_step p50",
      "cmd": "./run.sh emu --no-build churn.py --config experiments/prefix_scale/scenarios/sprint_twostep_emu_p50_burst.json --out {run_root}/emu --mode two_step --prefixes 50 --append"
    }
  ]
}
