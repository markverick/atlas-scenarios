{
  "_comment": "Near-threshold PrefixSync sweep with snapshots explicitly enabled. Run with: python3 jobs.py start jobs_threshold_near50_snapshots.json",
  "jobs": [
    {
      "name": "build",
      "cmd": "./run.sh build"
    },
    {
      "name": "two_step snapshots p{prefixes}",
      "cmd": "./run.sh sim --no-build churn.py --config scenarios/churn_prefix_scale_sprint_sim_snapshots.json --out results/sim_churn_threshold_near50_snapshots --mode two_step --prefixes {prefixes} --append",
      "matrix": {"prefixes": [40, 45, 50, 55, 60]}
    }
  ]
}